{
  "name": "pockcode",
  "version": "0.0.25",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monokaijs/pockcode.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "pockcode": "./dist/pockcode.js"
  },
  "files": [
    "build/client",
    "dist",
    "prisma/schema.prisma"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build --config vite.client.config.ts && vite build --config vite.cli.config.ts",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "prepack": "npm run build",
    "preview": "node dist/pockcode.js --host 0.0.0.0",
    "test": "vitest run",
    "test:real-codex": "node scripts/real-codex-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@openai/codex": "^0.142.5",
    "@prisma/client": "^6.19.3",
    "@react-router/dev": "^7.15.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.15.1",
    "smol-toml": "^1.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
