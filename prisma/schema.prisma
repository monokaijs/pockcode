generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProviderAccountStatus {
  DISCONNECTED
  AUTHENTICATING
  CONNECTED
  INVALIDATED
  ERROR
}

enum ChatStatus {
  IDLE
  RUNNING
  ARCHIVED
}

enum MessageScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MessageScheduleRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model ProviderSetting {
  providerId String   @id
  settings   Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PluginSetting {
  pluginId  String   @id
  enabled   Boolean  @default(false)
  settings  Json     @default("{}")
  secrets   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PluginState {
  pluginId  String   @id
  state     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  endpoint       String   @id
  expirationTime Float?
  keys           Json
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WorkspaceHistory {
  id           String   @default(uuid()) @unique
  path         String   @id
  name         String
  isOpen       Boolean  @default(false)
  lastOpenedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isOpen, lastOpenedAt])
  @@index([lastOpenedAt])
}

model ProviderAccount {
  id               String                @id @default(uuid())
  providerId       String
  displayName      String
  status           ProviderAccountStatus @default(DISCONNECTED)
  settings         Json                  @default("{}")
  runtimeDefaults  Json                  @default("{}")
  authState        Json?
  lastAuthUrl      String?
  lastAuthMode     String?
  lastAuthLoginId  String?
  lastAuthUserCode String?
  lastError        String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  chats            Chat[]                @relation("ChatAccount")
  runs             ChatRun[]             @relation("RunAccount")

  @@index([providerId])
  @@index([status])
}

model McpServer {
  id                String                  @id @default(uuid())
  name              String                  @unique
  displayName       String?
  transport         String
  config            Json                    @default("{}")
  enabled           Boolean                 @default(true)
  required          Boolean                 @default(false)
  startupTimeoutSec Float?
  toolTimeoutSec    Float?
  toolPolicy        Json                    @default("{}")
  adapterSettings   Json                    @default("{}")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  installations     McpServerInstallation[]
}

model McpServerInstallation {
  id         String    @id @default(uuid())
  serverId   String
  providerId String
  accountId  String
  enabled    Boolean   @default(true)
  lastSyncAt DateTime?
  lastStatus String?
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  server     McpServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, providerId, accountId])
  @@index([providerId, accountId])
}

model Chat {
  id                String           @id @default(uuid())
  providerId        String
  accountId         String?
  autoRotateAccount Boolean          @default(false)
  title             String
  workingDirectory  String?
  model             String?
  reasoningEffort   String?
  serviceTier       String?
  collaborationMode String           @default("default")
  permissionMode    String           @default("default")
  status            ChatStatus       @default(IDLE)
  externalThreadId  String?
  lastActivityAt    DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  account           ProviderAccount? @relation("ChatAccount", fields: [accountId], references: [id], onDelete: SetNull)
  runs              ChatRun[]

  @@index([providerId])
  @@index([accountId])
  @@index([updatedAt])
  @@index([lastActivityAt])
  @@index([externalThreadId])
}

model ChatRun {
  id                   String           @id @default(uuid())
  chatId               String
  providerId           String
  accountId            String?
  status               RunStatus        @default(QUEUED)
  request              Json             @default("{}")
  error                String?
  externalTurnId       String?
  interruptRequestedAt DateTime?
  startedAt            DateTime?
  endedAt              DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  chat                 Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  account              ProviderAccount? @relation("RunAccount", fields: [accountId], references: [id], onDelete: SetNull)

  @@index([chatId, createdAt])
  @@index([providerId])
  @@index([accountId])
  @@index([externalTurnId])
}

model MessageSchedule {
  id                String                @id @default(uuid())
  title             String
  message           String
  workingDirectory  String
  chatId            String?
  providerId        String
  accountId         String?
  model             String?
  reasoningEffort   String?
  serviceTier       String?
  collaborationMode String                @default("default")
  permissionMode    String                @default("default")
  goalObjective     String?
  status            MessageScheduleStatus @default(ACTIVE)
  recurrence        Json                  @default("{}")
  nextRunAt         DateTime?
  lastRunAt         DateTime?
  lastRunStatus     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  runs              MessageScheduleRun[]

  @@index([workingDirectory])
  @@index([status, nextRunAt])
  @@index([chatId])
  @@index([accountId])
}

model MessageScheduleRun {
  id           String                   @id @default(uuid())
  scheduleId   String
  chatId       String?
  chatRunId    String?
  scheduledFor DateTime
  status       MessageScheduleRunStatus @default(QUEUED)
  error        String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  schedule     MessageSchedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, scheduledFor])
  @@index([chatId])
  @@index([chatRunId])
  @@index([status])
}
